# Sample environment file for the FortiSandbox API mock service.
# Copy to /etc/fsa-mock.env and edit as needed.

# Listen address. The container image defaults to :8080.
FSA_ADDR=:8080

# Optional credentials. Leave both empty to accept any user/passwd pair.
#FSA_USER=admin
#FSA_PASSWORD=changeme

# Comma-separated list of sha256 (64 hex), sha1 (40 hex) and/or md5 (32 hex)
# hashes that must be reported as malicious. Sha256 of the EICAR test string
# is shown below.
FSA_BAD_HASHES=275a021bbfb6489e54d471899f7db9d1663fc695ec2fe2a2c4538aabf651fd0f

# Or a JSON file (objects with sha256/md5/malware_name/score/category):
#FSA_BAD_HASHES_FILE=/etc/fsa-mock/bad-hashes.json

# Default verdict fields applied when a bad-hash entry does not override them.
FSA_MALWARE_NAME=EICAR_TEST_FILE
FSA_SCORE=90
FSA_CATEGORY=Malware
